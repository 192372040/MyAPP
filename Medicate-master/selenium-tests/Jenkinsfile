pipeline {
    agent any

    tools {
        jdk 'Java17'
        maven 'Maven3'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install System Dependencies') {
            steps {
                sh '''
                    echo "Checking/Installing Chrome on agent node..."
                    # Check if running in Linux environment and install dependencies
                    if [ -f /etc/debian_version ]; then
                        sudo apt-get update && sudo apt-get install -y google-chrome-stable
                    fi
                '''
            }
        }

        stage('Run Automated Tests') {
            steps {
                dir('selenium-tests') {
                    sh 'mvn clean test -Dbrowser=chrome -Dheadless=true -DappUrl=http://localhost:8080'
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'selenium-tests/reports/**', allowEmptyArchive: true
            archiveArtifacts artifacts: 'selenium-tests/allure-results/**', allowEmptyArchive: true
        }
    }
}
