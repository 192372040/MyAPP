<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Healthcare App Suite" parallel="methods" thread-count="4" verbose="1">
    
    <!-- Register HTML and Allure reporting listeners -->
    <listeners>
        <listener class-name="com.medicate.framework.listeners.TestListener" />
    </listeners>

    <test name="Chrome Functional Tests">
        <parameter name="browser" value="chrome" />
        <parameter name="headless" value="true" />
        <parameter name="appUrl" value="http://localhost:8080" />
        <classes>
            <class name="com.medicate.tests.HealthcareTests" />
        </classes>
    </test>
</suite>
